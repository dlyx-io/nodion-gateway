# Nodion API base URL
NODION_API_BASE_URL=https://api.nodion.com/v1

# Gateway port
PORT=3000

# Initial admin key (registered on first start)
ADMIN_BOOTSTRAP_KEY=change-me-to-a-secure-random-string

# Database dialect: sqlite | pg
DB_DIALECT=sqlite

# SQLite database path (only for sqlite)
DB_PATH=./data/gateway.db

# PostgreSQL connection URL (only for pg)
# DATABASE_URL=postgres://user:password@host:5432/dbname
